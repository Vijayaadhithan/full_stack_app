# Copy this file to release.env (do not commit release.env) and fill real values.
# Then run from doorstep-android:
#   set -a; source ./release.env; set +a
#   ./gradlew clean bundleRelease

VERSION_CODE=2
VERSION_NAME=1.0.1

# Comma-separated SPKI SHA-256 pins. Prefix optional; both forms are accepted:
#   sha256/BASE64_PIN,sha256/BACKUP_BASE64_PIN
API_CERT_PINS=sha256/REPLACE_WITH_REAL_PIN,sha256/REPLACE_WITH_BACKUP_PIN

# Upload key (or app signing key if you are self-managing signing)
RELEASE_KEYSTORE_FILE=/absolute/path/to/upload-keystore.jks
RELEASE_KEYSTORE_PASSWORD=REPLACE_WITH_STORE_PASSWORD
RELEASE_KEY_ALIAS=upload
RELEASE_KEY_PASSWORD=REPLACE_WITH_KEY_PASSWORD
